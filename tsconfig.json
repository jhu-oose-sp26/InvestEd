{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@finnhub-data-pipeline": [
        "./finnhub_data_pipeline"
      ],
      "@finnhub-data-pipeline/*": [
        "./finnhub_data_pipeline/*"
      ],
      "@alpaca-data-pipeline": [
        "./alpaca_data_pipeline"
      ],
      "@alpaca-data-pipeline/*": [
        "./alpaca_data_pipeline/*"
      ],
      "@candle-supabase-pipeline": [
        "./candle_supabase_pipeline"
      ],
      "@candle-supabase-pipeline/*": [
        "./candle_supabase_pipeline/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "finnhub_data_pipeline/**/*.ts",
    "alpaca_data_pipeline/**/*.ts",
    "candle_supabase_pipeline/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}