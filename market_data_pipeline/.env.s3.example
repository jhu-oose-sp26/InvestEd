# Copy this file to market_data_pipeline/.env.s3 and fill your own values.
# This file is for local development only. Do not commit credentials.

# Preferred auth: use AWS profile from ~/.aws/credentials
AWS_PROFILE=default

# Alternative auth (only if not using AWS_PROFILE):
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key

AWS_REGION=us-east-2
S3_BUCKET=oose-day-stocks-prices-bucket
S3_PREFIX=
