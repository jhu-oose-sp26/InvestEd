# Database (required for app and Docker Compose)
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=postgres
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@your_host:5432/${POSTGRES_DB}?schema=public"
HOST=your_host
PORT=5432

# Finnhub real-time quotes (optional – for live price, graphs, UI)
# Get a free key at https://finnhub.io/dashboard
FINNHUB_API_KEY=your_key_here

# Candle pipeline + /api/candles + /api/quote-snapshots use @supabase/supabase-js with ONLY these names (no SUPABASE_*):
#   HOST         → Supabase project URL (https://xxxx.supabase.co)
#   POSTGRES_PASSWORD → Supabase "service_role" JWT from Project Settings → API
# If you use the same .env for local Docker Postgres, either use a separate env for Supabase deploys or temporarily set HOST/POSTGRES_PASSWORD to those Supabase values when testing candles.
# DATABASE_URL, POSTGRES_USER, POSTGRES_DB, PORT above are for Prisma/local DB; the candle client does not read them.

# Apply supabase/migrations/20260329120000_market_candles.sql then 20260329130000_market_quote_snapshots.sql

# Alpaca Market Data
ALPAKA_API_KEY=your_key_here
ALPAKA_API_SECRET=your_secret_key

# Firebase — client config (browser). Use NEXT_PUBLIC_* so Next.js exposes them to the client SDK.
NEXT_PUBLIC_FIREBASE_API_KEY=your_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
# Service account email (from JSON "client_email"); also used by Firebase Admin when FIREBASE_SERVICE_ACCOUNT_KEY is PEM-only.
NEXT_PUBLIC_FIREBASE_CLIENT_EMAIL=your_client_email
# PEM multiline in double quotes is OK (real newlines or \n).
FIREBASE_SERVICE_ACCOUNT_KEY=your_service_account_key_here

