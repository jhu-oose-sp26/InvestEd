# Database (required for app and Docker Compose)
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=oops_db
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"

# Finnhub real-time quotes (optional – for live price, graphs, UI)
# Get a free key at https://finnhub.io/dashboard
# FINNHUB_API_KEY=

# Supabase (optional – Alpaca bars + Finnhub quote snapshots for chart inputs)
# Apply supabase/migrations/20260329120000_market_candles.sql then 20260329130000_market_quote_snapshots.sql
# Service role key: server only, never in the browser.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Alpaca Market Data (optional – ~15m delayed 1Min bars vs Finnhub; local Prisma + Supabase sync)
# ALPAKA_API_KEY=
# ALPAKA_API_SECRET=
