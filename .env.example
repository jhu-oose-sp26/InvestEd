# Database (required for app and Docker Compose)
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=oops_db
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"
HOST=localhost
PORT=5432

# Finnhub real-time quotes (optional – for live price, graphs, UI)
# Get a free key at https://finnhub.io/dashboard
# FINNHUB_API_KEY=

# Candle pipeline + /api/candles + /api/quote-snapshots use @supabase/supabase-js with ONLY these names (no SUPABASE_*):
#   HOST         → Supabase project URL (https://xxxx.supabase.co)
#   POSTGRES_PASSWORD → Supabase "service_role" JWT from Project Settings → API
# If you use the same .env for local Docker Postgres, either use a separate env for Supabase deploys or temporarily set HOST/POSTGRES_PASSWORD to those Supabase values when testing candles.
# DATABASE_URL, POSTGRES_USER, POSTGRES_DB, PORT above are for Prisma/local DB; the candle client does not read them.

# Apply supabase/migrations/20260329120000_market_candles.sql then 20260329130000_market_quote_snapshots.sql

# Alpaca Market Data (optional – 1Min bars)
# ALPAKA_API_KEY=
# ALPAKA_API_SECRET=
