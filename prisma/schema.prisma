// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["tracing"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  /// Firebase Auth user id — set when the user first signs in via Firebase
  firebaseUid  String?   @unique
  name         String?
  /// Optional public handle (unique). If unset, `accountNumber` is used for display/tracking.
  username     String?   @unique
  /// Stable unique id (e.g. IED-…) assigned at signup for support and leaderboards.
  accountNumber String   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  portfolios        Portfolio[]
  customQuizzes     CustomQuiz[]
  dailyQuizResults  DailyQuizResult[]
  markets           Market[]
  marketPositions   MarketPosition[]
  limitOrders       LimitOrder[]

  @@map("users")
}

/// One row per user per UTC calendar day (YYYY-MM-DD) for the daily challenge.
model DailyQuizResult {
  id             String   @id @default(cuid())
  userId         String
  quizDate       String   @db.VarChar(10)
  correctCount   Int
  totalQuestions Int
  passed         Boolean
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizDate])
  @@index([userId])
  @@map("daily_quiz_results")
}

model Portfolio {
  id           String    @id @default(cuid())
  userId       String
  name         String    @default("My Portfolio") @db.VarChar(100)
  cashBalance  Decimal   @default(100000.00) @db.Decimal(15, 2) // Starting with $100,000 virtual cash
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades       Trade[]
  positions    Position[]

  @@index([userId])
  @@map("portfolios")
}

model Trade {
  id            String    @id @default(cuid())
  portfolioId   String
  symbol        String    // Stock ticker symbol (e.g., "AAPL")
  type          TradeType // BUY or SELL
  quantity      Int       // Number of shares
  price         Decimal   @db.Decimal(15, 2) // Price per share at execution
  totalValue    Decimal   @db.Decimal(15, 2) // quantity * price
  executedAt    DateTime  @default(now())
  
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([symbol])
  @@index([executedAt])
  @@map("trades")
}

model Position {
  id              String   @id @default(cuid())
  portfolioId     String
  symbol          String   // Stock ticker symbol
  quantity        Int      @default(0) // Current number of shares owned
  averageBuyPrice Decimal  @db.Decimal(15, 2) // Weighted average purchase price
  updatedAt       DateTime @updatedAt
  
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol]) // One position per portfolio per symbol
  @@index([portfolioId])
  @@map("positions")
}

model MarketPrice {
  id        String   @id @default(cuid())
  symbol    String
  timestamp DateTime // Full timestamp for intraday precision
  timeframe String   @default("1Min") // Bar interval: "1Min", "5Min", "15Min", etc.
  open      Decimal  @db.Decimal(15, 6)
  high      Decimal  @db.Decimal(15, 6)
  low       Decimal  @db.Decimal(15, 6)
  close     Decimal  @db.Decimal(15, 6)
  volume    BigInt?
  vwap      Decimal? @db.Decimal(15, 6) // Volume-weighted average price
  tradeCount Int?    @map("trade_count")  // Number of trades in the bar

  @@unique([symbol, timestamp, timeframe])
  @@index([symbol, timestamp])
  @@map("market_prices_realtime")
}

model QuarterlyReport {
  id            String   @id @default(cuid())
  symbol        String
  quarter       String   // e.g., "2024-Q2"
  statementDate String   // ISO date string, e.g., "2024-06-30"
  releaseDate   String   // ISO date string
  statements    Json     // { income: {...}, balance: {...}, cashflow: {...} }
  performance   Json     // PerformanceWindow shape
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([symbol, quarter])
  @@index([symbol])
  @@index([quarter])
  @@map("quarterly_reports")
}

model CustomQuiz {
  id          String              @id @default(cuid())
  title       String              @db.VarChar(200)
  description String?             @db.VarChar(1000)
  userId      String
  isPublic    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   CustomQuizQuestion[]

  @@index([userId])
  @@index([isPublic])
  @@map("custom_quizzes")
}

model CustomQuizQuestion {
  id            String     @id @default(cuid())
  quizId        String
  prompt        String     @db.VarChar(2000)
  options       Json       // string[] — array of answer option strings
  correctAnswer String     @db.VarChar(2000)
  context       String?    @db.VarChar(4000)
  order         Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  quiz          CustomQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("custom_quiz_questions")
}

model Market {
  id             String         @id @default(cuid())
  creatorId      String
  title          String         @db.VarChar(200)
  description    String?        @db.VarChar(2000)
  resolutionDate DateTime
  status         MarketStatus   @default(OPEN)
  outcome        Boolean?       // true = YES, false = NO, null = unresolved
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  creator        User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  positions      MarketPosition[]
  limitOrders    LimitOrder[]

  @@index([creatorId])
  @@index([status])
  @@map("markets")
}

model MarketPosition {
  id          String   @id @default(cuid())
  userId      String
  marketId    String
  yesQuantity Int      @default(0)
  noQuantity  Int      @default(0)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId])
  @@index([marketId])
  @@map("market_positions")
}

model LimitOrder {
  id         String      @id @default(cuid())
  userId     String
  marketId   String
  side       OrderSide   // YES or NO
  orderType  OrderType   @default(LIMIT)
  limitPrice Decimal     @db.Decimal(15, 4) // 0.01–1.00
  quantity   Int
  status     OrderStatus @default(OPEN)
  createdAt  DateTime    @default(now())
  filledAt   DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  market     Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([marketId, status])
  @@map("limit_orders")
}

enum TradeType {
  BUY
  SELL
}

enum OrderSide {
  YES
  NO
}

enum OrderType {
  LIMIT
  IOC
}

enum MarketStatus {
  OPEN
  RESOLVED
  CANCELLED
}

enum OrderStatus {
  OPEN
  FILLED
  CANCELLED
  EXPIRED
}
